IMAGE_OWNER=your-docker-username

# JWT
JWT_SECRET=replace-with-strong-base64-encoded-256-bit-key
JWT_EXPIRATION_MS=86400000

# Email (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=you@gmail.com

# Frontend base URL
FRONTEND_BASE_URL=http://localhost:3000

# Push Notifications (VAPID)
# Leave blank on first run — backend prints generated keys to logs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@gmail.com
